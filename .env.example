# SupaWriter API - Environment Configuration Example
# Copy this file to .env and update with your local values.
# Never commit .env with real secrets.

# ===== Application =====
APP_NAME=SupaWriter API
APP_VERSION=2.0.0
DEBUG=false
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-use-long-random-string

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080  # 7 days

# API Configuration
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ===== Database (PostgreSQL) =====
# Option 1: Use individual components
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supawriter
POSTGRES_USER=supawriter
POSTGRES_PASSWORD=your_password_here

# Option 2: Use full DATABASE_URL (overrides individual components)
# DATABASE_URL=postgresql://user:password@host:port/database

# Connection Pool Settings
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=3600
POSTGRES_POOL_PRE_PING=true

# Query Settings
POSTGRES_ECHO=false
POSTGRES_ECHO_POOL=false

# ===== Redis =====
# Option 1: Use individual components
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Option 2: Use full REDIS_URL (overrides individual components)
# REDIS_URL=redis://:password@host:port/db

# Connection Pool Settings
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# ===== Rate Limiting =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_USE_REDIS=true
RATE_LIMIT_PUBLIC_REQUESTS_PER_MINUTE=10

# Paths to exclude from rate limiting (comma-separated)
# RATE_LIMIT_EXCLUDE_PATHS=["/health","/metrics","/docs","/openapi.json"]

# ===== Quota Management =====
QUOTA_ENABLED=true

# Default Quotas
QUOTA_DEFAULT_ARTICLE_DAILY_LIMIT=10
QUOTA_DEFAULT_ARTICLE_MONTHLY_LIMIT=100
QUOTA_DEFAULT_API_DAILY_LIMIT=1000
QUOTA_DEFAULT_API_MONTHLY_LIMIT=10000
QUOTA_DEFAULT_STORAGE_LIMIT_MB=1000

# ===== Audit Logging =====
AUDIT_ENABLED=true
AUDIT_LOG_REQUEST_BODY=true
AUDIT_LOG_RESPONSE_BODY=false
AUDIT_LOG_HEADERS=true

# Sensitive fields to filter (comma-separated)
# AUDIT_SENSITIVE_FIELDS=["password","token","api_key","secret","authorization","cookie","session"]

# ===== Caching =====
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300  # 5 minutes

# Cache TTLs for specific data types (seconds)
CACHE_USER_TTL=600      # 10 minutes
CACHE_QUOTA_TTL=60      # 1 minute
CACHE_ARTICLE_LIST_TTL=300  # 5 minutes

# ===== Monitoring =====
MONITORING_ENABLED=true
MONITORING_PROMETHEUS_ENABLED=true

# Slow query threshold (seconds)
MONITORING_SLOW_QUERY_THRESHOLD=1.0

# Health check interval (seconds)
MONITORING_HEALTH_CHECK_INTERVAL=30

# ===== OAuth Providers =====
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# WeChat OAuth (if applicable)
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# ===== External Services =====
# OpenAI API
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4000

# Other AI Services (if applicable)
DEEPSEEK_API_KEY=your_deepseek_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ===== Session =====
SESSION_SECRET_KEY=change-me-in-production-use-long-random-string

# ===== TrendRadar =====
TRENDRADAR_API_URL=http://localhost:8765

# ===== Frontend URLs =====
CREATOR_URL=http://localhost:3000
COMMUNITY_URL=http://localhost:3001

# ===== Development Settings =====
# Set to true to enable debug mode (shows detailed errors)
# DEBUG=true

# Set to true to enable SQL query logging
# POSTGRES_ECHO=true

# ===== Production Settings =====
# For production, make sure to:
# 1. Set DEBUG=false
# 2. Use strong SECRET_KEY and SESSION_SECRET_KEY
# 3. Use REDIS_URL with password
# 4. Set RATE_LIMIT_USE_REDIS=true
# 5. Disable POSTGRES_ECHO
# 6. Use appropriate CORS_ORIGINS
# 7. Set MONITORING_ENABLED=true
# 8. Configure proper DATABASE_URL with SSL if needed

# Example production DATABASE_URL with SSL:
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Example production REDIS_URL with password:
# REDIS_URL=redis://:strong_password@redis.production.com:6379/0
