# SupaWriter PostgreSQL 环境变量配置示例
# 复制此文件为 .env 并修改相应配置
# 请仅在本地/私有环境填写真实密钥，勿提交 deployment/.env

# PostgreSQL 数据库配置
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=supawriter
POSTGRES_USER=supawriter

# pgAdmin 管理界面配置
PGADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE

# Redis 缓存配置（可选）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# 应用程序数据库连接配置
# 注意：这里的密码要与上面的 POSTGRES_PASSWORD 保持一致
DATABASE_URL=postgresql://supawriter:YOUR_SECURE_PASSWORD_HERE@postgres:5432/supawriter
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
ENCRYPTION_KEY=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
NEXTAUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_VALUE
NEXTAUTH_URL=https://your-domain.example.com
NEXT_PUBLIC_API_URL=/api/backend
INTERNAL_API_URL=http://backend:8000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret
SUPER_ADMIN_EMAILS=
# 留空表示禁用启动时的超级管理员提升；需要时填写逗号分隔邮箱列表

# 备份配置
BACKUP_SCHEDULE=0 2 * * *                     # 每天凌晨2点自动备份
BACKUP_RETENTION_DAYS=30                      # 保留30天的备份文件

# 安全提醒：
# 1. 请使用包含大小写字母、数字、特殊字符的强密码
# 2. 密码长度建议至少12位
# 3. 不要在代码仓库中提交包含真实密码的 .env 文件
# 4. 生产环境建议定期更换密码

# TrendRadar API（容器内通信地址）
TRENDRADAR_API_URL=http://trendradar:8765

# TrendRadar 降级 API
NEWSNOW_API_URL=https://newsnow.busiyi.world/api/s

# Worker 设置
SYNC_INTERVAL_MINUTES=10

# DockerHub 镜像仓库配置
DOCKERHUB_USERNAME=minokun
DOCKERHUB_TAG=latest

# 密码示例（请不要直接使用）：
# POSTGRES_PASSWORD=Sup@Writer2024!Pg$
# PGADMIN_PASSWORD=Admin@2024!Secure#
